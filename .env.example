# ─────────────────────────────────────────────────────────────────────────────
# ArogyaVault — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to Git.
# ─────────────────────────────────────────────────────────────────────────────

# ── AWS (General) ─────────────────────────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# ── AWS Cognito ───────────────────────────────────────────────────────────────
COGNITO_USER_POOL_ID=ap-south-1_xxxxxxxxx
COGNITO_CLIENT_ID=your_cognito_app_client_id
COGNITO_REGION=ap-south-1
# Cognito JWKS URL (auto-derived, but set explicitly for clarity):
# https://cognito-idp.{REGION}.amazonaws.com/{POOL_ID}/.well-known/jwks.json

# ── AWS RDS PostgreSQL ────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@your-rds-endpoint.rds.amazonaws.com:5432/arogyavault

# ── AWS S3 ────────────────────────────────────────────────────────────────────
S3_BUCKET_NAME=arogyavault-documents
S3_REGION=ap-south-1

# ── AWS SNS ───────────────────────────────────────────────────────────────────
SNS_REGION=ap-south-1

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here

# ── Redis (Upstash) ──────────────────────────────────────────────────────────
REDIS_URL=redis://your-upstash-url:6379
REDIS_TOKEN=your-upstash-token

# ── Service Ports ─────────────────────────────────────────────────────────────
BACKEND_PORT=8000
AI_SERVICE_PORT=8001

# ── Web App (Next.js public vars) ────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_AI_SERVICE_URL=http://localhost:8001

# ── Sentry ───────────────────────────────────────────────────────────────────
SENTRY_DSN=your-sentry-dsn-here
