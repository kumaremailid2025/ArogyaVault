{
  "name": "arogyavault",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "apps/web",
    "apps/backend",
    "apps/ai-service",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\" --ignore-path .gitignore"
  },
  "devDependencies": {
    "turbo": "latest",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0"
  }
}
